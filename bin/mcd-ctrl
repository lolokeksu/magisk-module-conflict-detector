#!/system/bin/sh
# Module Conflict Detector v1.3 entry point.

show_mobile_help() {
    cat <<EOFHELP
Module Conflict Detector $VERSION

Команды:
  scan          Проверка
  report        Отчёт
  boot-status   Автозапуск
  doctor        Диагностика
  snapshot      Снимки
  whitelist     Исключения
  config        Настройки
  clear         Очистка
  version       Версия

Быстрый запуск:
  mcd-ctrl scan --deep
  mcd-ctrl report

Только опасные:
  mcd-ctrl report \
    --critical-only

JSON-отчёт:
  mcd-ctrl report --json
EOFHELP
}

case "$1" in
    help|--help|-h|'')
        VERSION="v1.3"
        show_mobile_help
        exit 0
        ;;
esac

MCD_LIB_DIR="${MCD_LIB_DIR:-/data/adb/modules/ModuleConflictDetector/bin/lib}"
if [ ! -d "$MCD_LIB_DIR" ]; then
    MCD_SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" 2>/dev/null && pwd)
    MCD_LIB_DIR="$MCD_SCRIPT_DIR/lib"
fi

for MCD_LIB_PART in \
    00-runtime.sh \
    10-root-detection.sh \
    20-collection.sh \
    30-path-analysis.sh \
    40-resource-analysis.sh \
    50-commands.sh; do
    MCD_LIB_PATH="$MCD_LIB_DIR/$MCD_LIB_PART"
    if [ ! -r "$MCD_LIB_PATH" ]; then
        echo "! Missing Module Conflict Detector library: $MCD_LIB_PATH" >&2
        exit 127
    fi
    . "$MCD_LIB_PATH"
done

case "$1" in
    scan) do_scan "$@" ;;
    report) do_report "$@" ;;
    snapshot) do_snapshot "$@" ;;
    clear) do_clear "$@" ;;
    whitelist) do_whitelist "$@" ;;
    config) do_config "$@" ;;
    doctor) do_doctor ;;
    boot-status) do_boot_status ;;
    version|--version|-v) echo "Module Conflict Detector $VERSION ($VERSION_CODE)" ;;
    *)
        echo "! Неизвестная команда: $1"
        echo
        show_mobile_help
        exit 1
        ;;
esac
