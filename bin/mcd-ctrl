#!/system/bin/sh
# Module Conflict Detector v1.4 entry point.

MCD_SELF_BIN="$0"
export MCD_SELF_BIN
MCD_LIB_DIR="${MCD_LIB_DIR:-/data/adb/modules/ModuleConflictDetector/bin/lib}"
if [ ! -d "$MCD_LIB_DIR" ]; then
    MCD_SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" 2>/dev/null && pwd)
    MCD_LIB_DIR="$MCD_SCRIPT_DIR/lib"
fi

for MCD_LIB_PART in \
    00-runtime.sh \
    10-root-detection.sh \
    20-collection.sh \
    30-path-analysis.sh \
    40-resource-analysis.sh \
    50-commands.sh; do
    MCD_LIB_PATH="$MCD_LIB_DIR/$MCD_LIB_PART"
    if [ ! -r "$MCD_LIB_PATH" ]; then
        echo "! Missing library: $MCD_LIB_PATH" >&2
        exit 127
    fi
    . "$MCD_LIB_PATH"
done

case "$1" in
    scan) do_scan "$@" ;;
    report) do_report "$@" ;;
    explain) do_explain "$@" ;;
    baseline) do_baseline "$@" ;;
    export) do_export "$@" ;;
    self-test) do_self_test "$@" ;;
    snapshot) do_snapshot "$@" ;;
    clear) do_clear "$@" ;;
    whitelist) do_whitelist "$@" ;;
    config) do_config "$@" ;;
    doctor) do_doctor ;;
    boot-status) do_boot_status ;;
    menu)
        MCD_MENU="${MCD_LIB_DIR%/lib}/mcd-menu"
        [ -x "$MCD_MENU" ] || { echo "! Меню не найдено: $MCD_MENU"; exit 127; }
        exec sh "$MCD_MENU"
        ;;
    help-all) show_help_all ;;
    help|--help|-h) show_help ;;
    '')
        MCD_MENU="${MCD_LIB_DIR%/lib}/mcd-menu"
        [ -x "$MCD_MENU" ] || { echo "! Меню не найдено: $MCD_MENU"; exit 127; }
        exec sh "$MCD_MENU"
        ;;
    version|--version|-v) echo "Module Conflict Detector $VERSION ($VERSION_CODE)" ;;
    *) echo "! Неизвестная команда: $1"; echo; show_help; exit 1 ;;
esac
