#!/system/bin/sh
# Module Conflict Detector v1.2 - mcd-ctrl
# Read-only CLI for detecting Magisk / KernelSU / APatch module conflicts.

VERSION="v1.2"
SELF_ID="ModuleConflictDetector"

MCD_DIR="${MCD_DIR:-/data/adb/mcd}"
MODULES_DIR="${MCD_MODULES_DIR:-/data/adb/modules}"
REPORTS_DIR="$MCD_DIR/reports"
TMP_DIR="$MCD_DIR/tmp"
CONFIG_FILE="$MCD_DIR/config.conf"
WHITELIST_FILE="$MCD_DIR/whitelist.conf"
LOG_FILE="$MCD_DIR/conflicts.log"
JSON_FILE="$MCD_DIR/report.json"
LOCK_DIR="$MCD_DIR/.scan.lock"

ENTRY_FILE="$TMP_DIR/entries.tmp"
REPLACE_FILE="$TMP_DIR/replace_dirs.tmp"
PROP_FILE="$TMP_DIR/properties.tmp"
PATH_CONFLICTS_FILE="$TMP_DIR/path_conflicts.tmp"
REPLACE_CONFLICTS_FILE="$TMP_DIR/replace_conflicts.tmp"
REPLACE_MASKS_FILE="$TMP_DIR/replace_masks.tmp"
PROP_CONFLICTS_FILE="$TMP_DIR/property_conflicts.tmp"
JSON_ITEMS_FILE="$TMP_DIR/json_items.tmp"
COUNT_FILE="$TMP_DIR/conflict_count.tmp"

MOUNT_ROOTS="system vendor product system_ext odm"
QUIET=0
BOOT_MODE=0

for arg in "$@"; do
    case "$arg" in
        --quiet) QUIET=1 ;;
        --boot) BOOT_MODE=1 ;;
    esac
done

msg() {
    [ "$QUIET" = "0" ] && printf '%s\n' "$*"
}

ensure_dirs() {
    mkdir -p "$MCD_DIR" "$REPORTS_DIR" "$TMP_DIR" 2>/dev/null
    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" <<'CFG'
# Module Conflict Detector config
# 1 = scan after boot, 0 = manual scan only
auto_scan=1

# Delay after sys.boot_completed=1 before automatic scan
boot_delay_seconds=30

# Maximum path examples saved for one .replace masking conflict
replace_examples_limit=20
CFG
    fi
    [ -f "$WHITELIST_FILE" ] || : > "$WHITELIST_FILE"
}

get_config() {
    key="$1"
    def="$2"
    val=""
    if [ -f "$CONFIG_FILE" ]; then
        val=$(grep -E "^[[:space:]]*$key=" "$CONFIG_FILE" 2>/dev/null | tail -n 1 | cut -d= -f2-)
    fi
    [ -n "$val" ] && printf '%s' "$val" || printf '%s' "$def"
}

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g'
}

owners_to_json() {
    out=""
    for owner in $1; do
        esc=$(json_escape "$owner")
        if [ -n "$out" ]; then
            out="$out,\"$esc\""
        else
            out="\"$esc\""
        fi
    done
    printf '%s' "$out"
}

winner_from_owners() {
    printf '%s\n' $1 | sort | tail -n 1
}

severity_of_path() {
    case "$1" in
        */bin/*|*/xbin/*|*/apex/*|*/etc/init/*|*/etc/permissions/*|*/etc/sysconfig/*|*/etc/vintf/*|*sepolicy*)
            echo "CRITICAL" ;;
        */framework/*|*/priv-app/*|*/app/*|*/overlay/*|*/lib64/*|*/lib/*|*/build.prop|*/default.prop|*/system.prop)
            echo "HIGH" ;;
        */etc/*|*/fonts/*|*/media/*|*/usr/*)
            echo "MEDIUM" ;;
        *)
            echo "LOW" ;;
    esac
}

severity_of_prop() {
    case "$1" in
        ro.*|persist.*|sys.*|debug.*|dalvik.*|vendor.*|ctl.*)
            echo "HIGH" ;;
        *)
            echo "MEDIUM" ;;
    esac
}

in_whitelist() {
    path="$1"
    [ ! -f "$WHITELIST_FILE" ] && return 1
    while IFS= read -r line; do
        case "$line" in
            ''|'#'*) continue ;;
        esac
        [ "$line" = "$path" ] && return 0
    done < "$WHITELIST_FILE"
    return 1
}

scan_cleanup() {
    rm -f "$ENTRY_FILE" "$REPLACE_FILE" "$PROP_FILE" \
        "$PATH_CONFLICTS_FILE" "$REPLACE_CONFLICTS_FILE" \
        "$REPLACE_MASKS_FILE" "$PROP_CONFLICTS_FILE" \
        "$JSON_ITEMS_FILE" "$COUNT_FILE" 2>/dev/null
    rmdir "$LOCK_DIR" 2>/dev/null
}

acquire_scan_lock() {
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        msg "! Scan already running: $LOCK_DIR"
        exit 2
    fi
    trap 'scan_cleanup' EXIT HUP INT TERM
}

inc_count() {
    count=$(cat "$COUNT_FILE" 2>/dev/null)
    case "$count" in
        ''|*[!0-9]*) count=0 ;;
    esac
    echo $((count + 1)) > "$COUNT_FILE"
}

add_conflict() {
    ctype="$1"
    path="$2"
    severity="$3"
    owners="$4"
    winner="$5"
    detail="$6"

    modules_json=$(owners_to_json "$owners")
    ep=$(json_escape "$path")
    es=$(json_escape "$severity")
    et=$(json_escape "$ctype")
    ew=$(json_escape "$winner")
    ed=$(json_escape "$detail")

    {
        printf '[%s][%s] %s\n' "$severity" "$ctype" "$path"
        printf '    modules: %s\n' "$owners"
        [ -n "$winner" ] && printf '    likely_winner: %s\n' "$winner"
        [ -n "$detail" ] && printf '    detail: %s\n' "$detail"
        printf '\n'
    } >> "$LOG_FILE"

    printf '{"type":"%s","path":"%s","severity":"%s","modules":[%s],"likely_winner":"%s","detail":"%s"}\n' \
        "$et" "$ep" "$es" "$modules_json" "$ew" "$ed" >> "$JSON_ITEMS_FILE"

    inc_count
}

emit_entry() {
    base="$1"
    root="$2"
    fpath="$3"
    mod_name="$4"
    kind="$5"

    rel="${fpath#$base}"
    [ "$rel" = "$fpath" ] && return
    target="/$root$rel"

    case "$target" in
        */.replace) return ;;
    esac

    printf '%s|%s|%s\n' "$target" "$mod_name" "$kind" >> "$ENTRY_FILE"
}

emit_replace_dir() {
    base="$1"
    root="$2"
    rpath="$3"
    mod_name="$4"

    rel="${rpath#$base}"
    [ "$rel" = "$rpath" ] && return
    dir="${rel%/.replace}"
    target="/$root$dir"

    printf '%s|%s\n' "$target" "$mod_name" >> "$REPLACE_FILE"
}

scan_tree() {
    module_root="$1"
    mod_name="$2"
    root="$3"
    base="$module_root/$root"

    [ -d "$base" ] || return

    find "$base" -type f 2>/dev/null | while IFS= read -r fpath; do
        case "$fpath" in
            */.replace) continue ;;
        esac
        emit_entry "$base" "$root" "$fpath" "$mod_name" "file"
    done

    find "$base" -type l 2>/dev/null | while IFS= read -r fpath; do
        emit_entry "$base" "$root" "$fpath" "$mod_name" "symlink"
    done

    find "$base" -type c 2>/dev/null | while IFS= read -r fpath; do
        emit_entry "$base" "$root" "$fpath" "$mod_name" "whiteout"
    done

    find "$base" -name '.replace' -type f 2>/dev/null | while IFS= read -r rpath; do
        emit_replace_dir "$base" "$root" "$rpath" "$mod_name"
    done
}

scan_system_prop() {
    module_root="$1"
    mod_name="$2"
    prop_file="$module_root/system.prop"

    [ -f "$prop_file" ] || return

    sed -n 's/^[[:space:]]*\([^#[:space:]][^=[:space:]]*\)[[:space:]]*=.*/\1/p' "$prop_file" 2>/dev/null | while IFS= read -r key; do
        [ -n "$key" ] && printf '%s|%s\n' "$key" "$mod_name" >> "$PROP_FILE"
    done
}

module_has_mount_content() {
    module_root="$1"
    for root in $MOUNT_ROOTS; do
        [ -d "$module_root/$root" ] && return 0
    done
    [ -f "$module_root/system.prop" ] && return 0
    return 1
}

build_path_conflicts() {
    [ -s "$ENTRY_FILE" ] || return
    sort -u "$ENTRY_FILE" | sort -t '|' -k1,1 > "$TMP_DIR/entries.sorted.tmp"
    mv "$TMP_DIR/entries.sorted.tmp" "$ENTRY_FILE"

    awk -F'|' '
        function add_unique(list, item) {
            if (item == "") return list
            if (index(" " list " ", " " item " ") > 0) return list
            if (list == "") return item
            return list " " item
        }
        function flush() {
            if (path != "" && owner_count > 1) print path "|" owners "|" kinds
        }
        {
            if (NR == 1 || $1 != path) {
                flush()
                path = $1
                owners = $2
                kinds = $3
                seen = " " $2 " "
                owner_count = 1
            } else {
                if (index(seen, " " $2 " ") == 0) {
                    owners = owners " " $2
                    seen = seen $2 " "
                    owner_count++
                }
                kinds = add_unique(kinds, $3)
            }
        }
        END { flush() }
    ' "$ENTRY_FILE" > "$PATH_CONFLICTS_FILE"
}

build_replace_conflicts() {
    [ -s "$REPLACE_FILE" ] || return
    sort -u "$REPLACE_FILE" | sort -t '|' -k1,1 > "$TMP_DIR/replace.sorted.tmp"
    mv "$TMP_DIR/replace.sorted.tmp" "$REPLACE_FILE"

    awk -F'|' '
        function flush() {
            if (path != "" && owner_count > 1) print path "|" owners
        }
        {
            if (NR == 1 || $1 != path) {
                flush()
                path = $1
                owners = $2
                seen = " " $2 " "
                owner_count = 1
            } else if (index(seen, " " $2 " ") == 0) {
                owners = owners " " $2
                seen = seen $2 " "
                owner_count++
            }
        }
        END { flush() }
    ' "$REPLACE_FILE" > "$REPLACE_CONFLICTS_FILE"
}

build_replace_masks() {
    [ -s "$REPLACE_FILE" ] || return
    [ -s "$ENTRY_FILE" ] || return

    : > "$REPLACE_MASKS_FILE"

    while IFS='|' read -r rdir rmod; do
        [ -n "$rdir" ] || continue
        in_whitelist "$rdir" && continue

        while IFS='|' read -r fpath fmod fkind; do
            [ -n "$fpath" ] || continue
            [ "$rmod" = "$fmod" ] && continue
            in_whitelist "$fpath" && continue
            case "$fpath" in
                "$rdir"|"$rdir"/*)
                    printf '%s|%s|%s|%s\n' "$rdir" "$rmod" "$fmod" "$fpath" >> "$REPLACE_MASKS_FILE"
                    ;;
            esac
        done < "$ENTRY_FILE"
    done < "$REPLACE_FILE"

    [ -s "$REPLACE_MASKS_FILE" ] || return

    limit=$(get_config replace_examples_limit 20)
    case "$limit" in
        ''|*[!0-9]*) limit=20 ;;
    esac

    sort -t '|' -k1,1 -k2,2 "$REPLACE_MASKS_FILE" | awk -F'|' -v limit="$limit" '
        function add_unique(list, item) {
            if (item == "") return list
            if (index(" " list " ", " " item " ") > 0) return list
            if (list == "") return item
            return list " " item
        }
        function flush() {
            if (rdir != "") print rdir "|" replacer " " affected_modules "|" replacer "|" affected_count "|" examples
        }
        {
            key = $1 "|" $2
            if (NR == 1 || key != prev_key) {
                flush()
                prev_key = key
                rdir = $1
                replacer = $2
                affected_modules = $3
                affected_count = 1
                examples = $4
                example_count = 1
            } else {
                affected_modules = add_unique(affected_modules, $3)
                affected_count++
                if (example_count < limit) {
                    examples = examples ", " $4
                    example_count++
                }
            }
        }
        END { flush() }
    ' > "$TMP_DIR/replace_masks.grouped.tmp"

    mv "$TMP_DIR/replace_masks.grouped.tmp" "$REPLACE_MASKS_FILE"
}

build_property_conflicts() {
    [ -s "$PROP_FILE" ] || return
    sort -u "$PROP_FILE" | sort -t '|' -k1,1 > "$TMP_DIR/properties.sorted.tmp"
    mv "$TMP_DIR/properties.sorted.tmp" "$PROP_FILE"

    awk -F'|' '
        function flush() {
            if (key != "" && owner_count > 1) print key "|" owners
        }
        {
            if (NR == 1 || $1 != key) {
                flush()
                key = $1
                owners = $2
                seen = " " $2 " "
                owner_count = 1
            } else if (index(seen, " " $2 " ") == 0) {
                owners = owners " " $2
                seen = seen $2 " "
                owner_count++
            }
        }
        END { flush() }
    ' "$PROP_FILE" > "$PROP_CONFLICTS_FILE"
}

write_json_report() {
    scan_time="$1"
    mod_count="$2"
    entries_count="$3"
    replace_count="$4"
    prop_count="$5"
    conflict_count="$6"

    items=$(awk 'BEGIN { first = 1 } { if (!first) printf ","; printf "%s", $0; first = 0 }' "$JSON_ITEMS_FILE" 2>/dev/null)

    cat > "$JSON_FILE" <<EOFJSON
{
  "tool": "Module Conflict Detector",
  "version": "$VERSION",
  "scan_time": "$scan_time",
  "boot_scan": $BOOT_MODE,
  "modules_scanned": $mod_count,
  "entries_scanned": $entries_count,
  "replace_dirs_scanned": $replace_count,
  "property_keys_scanned": $prop_count,
  "conflicts_count": $conflict_count,
  "conflicts": [$items]
}
EOFJSON

    cp -f "$JSON_FILE" "$REPORTS_DIR/report-latest.json" 2>/dev/null
    cp -f "$LOG_FILE" "$REPORTS_DIR/conflicts-latest.log" 2>/dev/null
}

do_scan() {
    ensure_dirs
    [ -d "$MODULES_DIR" ] || { msg "! Modules directory not found: $MODULES_DIR"; exit 1; }
    acquire_scan_lock

    : > "$ENTRY_FILE"
    : > "$REPLACE_FILE"
    : > "$PROP_FILE"
    : > "$PATH_CONFLICTS_FILE"
    : > "$REPLACE_CONFLICTS_FILE"
    : > "$REPLACE_MASKS_FILE"
    : > "$PROP_CONFLICTS_FILE"
    : > "$JSON_ITEMS_FILE"
    echo 0 > "$COUNT_FILE"

    scan_time=$(date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null)
    [ -n "$scan_time" ] || scan_time="unknown"

    {
        printf 'Module Conflict Detector %s\n' "$VERSION"
        printf 'Scan time: %s\n' "$scan_time"
        printf 'Modules dir: %s\n' "$MODULES_DIR"
        printf '\n'
    } > "$LOG_FILE"

    mod_count=0

    for module_dir in "$MODULES_DIR"/*; do
        [ -d "$module_dir" ] || continue
        module_root="${module_dir%/}"
        mod_name=$(basename "$module_root")

        [ "$mod_name" = "$SELF_ID" ] && continue
        [ -f "$module_root/disable" ] && continue
        [ -f "$module_root/remove" ] && continue
        module_has_mount_content "$module_root" || continue

        mod_count=$((mod_count + 1))

        for root in $MOUNT_ROOTS; do
            scan_tree "$module_root" "$mod_name" "$root"
        done

        scan_system_prop "$module_root" "$mod_name"
    done

    build_path_conflicts
    build_replace_conflicts
    build_replace_masks
    build_property_conflicts

    if [ -s "$PATH_CONFLICTS_FILE" ]; then
        while IFS='|' read -r path owners kinds; do
            [ -n "$path" ] || continue
            in_whitelist "$path" && continue
            winner=$(winner_from_owners "$owners")
            severity=$(severity_of_path "$path")
            add_conflict "path_collision" "$path" "$severity" "$owners" "$winner" "entry_types=$kinds"
        done < "$PATH_CONFLICTS_FILE"
    fi

    if [ -s "$REPLACE_CONFLICTS_FILE" ]; then
        while IFS='|' read -r path owners; do
            [ -n "$path" ] || continue
            in_whitelist "$path" && continue
            winner=$(winner_from_owners "$owners")
            severity=$(severity_of_path "$path")
            add_conflict "replace_dir_collision" "$path" "$severity" "$owners" "$winner" "multiple modules declare .replace for this directory"
        done < "$REPLACE_CONFLICTS_FILE"
    fi

    if [ -s "$REPLACE_MASKS_FILE" ]; then
        while IFS='|' read -r path owners replacer affected_count examples; do
            [ -n "$path" ] || continue
            in_whitelist "$path" && continue
            severity=$(severity_of_path "$path")
            detail="replace_owner=$replacer; masked_paths=$affected_count; examples=$examples"
            add_conflict "replace_masks_tree" "$path" "$severity" "$owners" "$replacer" "$detail"
        done < "$REPLACE_MASKS_FILE"
    fi

    if [ -s "$PROP_CONFLICTS_FILE" ]; then
        while IFS='|' read -r key owners; do
            [ -n "$key" ] || continue
            prop_path="system.prop:$key"
            in_whitelist "$prop_path" && continue
            winner=$(winner_from_owners "$owners")
            severity=$(severity_of_prop "$key")
            add_conflict "property_collision" "$prop_path" "$severity" "$owners" "$winner" "same system.prop key is defined by multiple modules"
        done < "$PROP_CONFLICTS_FILE"
    fi

    entries_count=$(wc -l < "$ENTRY_FILE" 2>/dev/null | tr -d ' ')
    replace_count=$(wc -l < "$REPLACE_FILE" 2>/dev/null | tr -d ' ')
    prop_count=$(wc -l < "$PROP_FILE" 2>/dev/null | tr -d ' ')
    conflict_count=$(cat "$COUNT_FILE" 2>/dev/null)

    case "$entries_count" in ''|*[!0-9]*) entries_count=0 ;; esac
    case "$replace_count" in ''|*[!0-9]*) replace_count=0 ;; esac
    case "$prop_count" in ''|*[!0-9]*) prop_count=0 ;; esac
    case "$conflict_count" in ''|*[!0-9]*) conflict_count=0 ;; esac

    write_json_report "$scan_time" "$mod_count" "$entries_count" "$replace_count" "$prop_count" "$conflict_count"

    if [ "$conflict_count" -gt 0 ]; then
        msg "! Found conflicts: $conflict_count (modules=$mod_count, entries=$entries_count, replace_dirs=$replace_count, props=$prop_count)"
        msg "  Report: mcd-ctrl report"
        msg "  JSON:   mcd-ctrl report --json"
    else
        msg "- No conflicts found (modules=$mod_count, entries=$entries_count, replace_dirs=$replace_count, props=$prop_count)"
    fi

    scan_cleanup
    trap - EXIT HUP INT TERM
}

do_report() {
    case "$2" in
        --json)
            if [ -f "$JSON_FILE" ]; then
                cat "$JSON_FILE"
            else
                echo '{"error":"no scan data","hint":"run mcd-ctrl scan"}'
            fi
            ;;
        --text|'' )
            if [ -s "$LOG_FILE" ]; then
                cat "$LOG_FILE"
            else
                echo "- No text report. Run: mcd-ctrl scan"
            fi
            ;;
        *)
            echo "Usage: mcd-ctrl report [--json|--text]"
            exit 1
            ;;
    esac
}

do_clear() {
    ensure_dirs
    rm -f "$LOG_FILE" "$JSON_FILE" "$REPORTS_DIR/report-latest.json" "$REPORTS_DIR/conflicts-latest.log" 2>/dev/null
    rm -rf "$TMP_DIR" "$LOCK_DIR" 2>/dev/null
    mkdir -p "$TMP_DIR" 2>/dev/null
    if [ "$2" = "--all" ]; then
        rm -f "$WHITELIST_FILE" "$CONFIG_FILE" 2>/dev/null
        ensure_dirs
        msg "- Cleared reports, temp files, whitelist and config"
    else
        msg "- Cleared reports and temp files"
    fi
}

do_whitelist() {
    ensure_dirs
    case "$2" in
        add)
            [ -n "$3" ] || { echo "Usage: mcd-ctrl whitelist add /system/path"; exit 1; }
            if grep -Fxq -- "$3" "$WHITELIST_FILE" 2>/dev/null; then
                msg "- Already whitelisted: $3"
            else
                printf '%s\n' "$3" >> "$WHITELIST_FILE"
                msg "+ Whitelisted: $3"
            fi
            ;;
        remove)
            [ -n "$3" ] || { echo "Usage: mcd-ctrl whitelist remove /system/path"; exit 1; }
            tmp="$TMP_DIR/whitelist.new"
            grep -Fvx -- "$3" "$WHITELIST_FILE" > "$tmp" 2>/dev/null || :
            mv "$tmp" "$WHITELIST_FILE"
            msg "- Removed from whitelist: $3"
            ;;
        list)
            if [ -s "$WHITELIST_FILE" ]; then
                sed '/^[[:space:]]*#/d; /^[[:space:]]*$/d' "$WHITELIST_FILE"
            else
                echo "- Whitelist is empty"
            fi
            ;;
        *)
            echo "Usage: mcd-ctrl whitelist add|remove|list [/system/path]"
            exit 1
            ;;
    esac
}

valid_config_key() {
    case "$1" in
        auto_scan|boot_delay_seconds|replace_examples_limit) return 0 ;;
        *) return 1 ;;
    esac
}

set_config_value() {
    key="$1"
    value="$2"
    tmp="$TMP_DIR/config.new"

    valid_config_key "$key" || { echo "! Unknown config key: $key"; exit 1; }

    case "$key" in
        auto_scan)
            case "$value" in 0|1) ;; *) echo "! auto_scan must be 0 or 1"; exit 1 ;; esac
            ;;
        boot_delay_seconds|replace_examples_limit)
            case "$value" in ''|*[!0-9]*) echo "! $key must be numeric"; exit 1 ;; esac
            ;;
    esac

    if grep -q "^$key=" "$CONFIG_FILE" 2>/dev/null; then
        sed "s|^$key=.*|$key=$value|" "$CONFIG_FILE" > "$tmp"
        mv "$tmp" "$CONFIG_FILE"
    else
        printf '%s=%s\n' "$key" "$value" >> "$CONFIG_FILE"
    fi

    msg "+ Config updated: $key=$value"
}

do_config() {
    ensure_dirs
    case "$2" in
        list|'')
            sed '/^[[:space:]]*#/d; /^[[:space:]]*$/d' "$CONFIG_FILE"
            ;;
        get)
            [ -n "$3" ] || { echo "Usage: mcd-ctrl config get key"; exit 1; }
            valid_config_key "$3" || { echo "! Unknown config key: $3"; exit 1; }
            get_config "$3" ""
            echo
            ;;
        set)
            [ -n "$3" ] && [ -n "$4" ] || { echo "Usage: mcd-ctrl config set key value"; exit 1; }
            set_config_value "$3" "$4"
            ;;
        *)
            echo "Usage: mcd-ctrl config list|get|set [key] [value]"
            exit 1
            ;;
    esac
}

do_doctor() {
    ensure_dirs
    echo "Module Conflict Detector $VERSION"
    echo "id: $SELF_ID"
    echo "mcd_dir: $MCD_DIR"
    echo "modules_dir: $MODULES_DIR"
    echo "config: $CONFIG_FILE"
    echo "whitelist: $WHITELIST_FILE"
    echo

    if [ -d "$MODULES_DIR" ]; then
        total=$(find "$MODULES_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
        echo "modules_dir_status=OK"
        echo "modules_total=$total"
    else
        echo "modules_dir_status=MISSING"
    fi

    if [ -w "$MCD_DIR" ]; then
        echo "mcd_dir_writable=1"
    else
        echo "mcd_dir_writable=0"
    fi

    echo "auto_scan=$(get_config auto_scan 1)"
    echo "boot_delay_seconds=$(get_config boot_delay_seconds 30)"
    echo "replace_examples_limit=$(get_config replace_examples_limit 20)"
}

show_help() {
    cat <<EOFHELP
Module Conflict Detector $VERSION

Usage:
  mcd-ctrl scan [--quiet]
  mcd-ctrl report [--json|--text]
  mcd-ctrl clear [--all]
  mcd-ctrl whitelist add /system/path
  mcd-ctrl whitelist remove /system/path
  mcd-ctrl whitelist list
  mcd-ctrl config list
  mcd-ctrl config get auto_scan
  mcd-ctrl config set auto_scan 0|1
  mcd-ctrl config set boot_delay_seconds 30
  mcd-ctrl config set replace_examples_limit 20
  mcd-ctrl doctor
  mcd-ctrl version

Detected conflict classes:
  path_collision         same target path from multiple modules
  replace_dir_collision  same .replace directory from multiple modules
  replace_masks_tree     .replace directory masks another module's files
  property_collision     same system.prop key from multiple modules
EOFHELP
}

case "$1" in
    scan) do_scan "$@" ;;
    report) do_report "$@" ;;
    clear) do_clear "$@" ;;
    whitelist) do_whitelist "$@" ;;
    config) do_config "$@" ;;
    doctor) do_doctor ;;
    version|--version|-v) echo "Module Conflict Detector $VERSION" ;;
    help|--help|-h|'') show_help ;;
    *)
        echo "! Unknown command: $1"
        echo
        show_help
        exit 1
        ;;
esac
