#!/system/bin/sh
# Module Conflict Detector v1.0 - mcd-ctrl
# Использование: mcd-ctrl scan|report|clear [--json|--quiet]

MCD_DIR="/data/adb/mcd"
MODULES_DIR="/data/adb/modules"
SELF_ID="ModuleConflictDetector"

LOG_FILE="$MCD_DIR/conflicts.log"
JSON_FILE="$MCD_DIR/report.json"
MAP_FILE="$MCD_DIR/.filemap.tmp"

QUIET=0
case "$2" in --quiet) QUIET=1 ;; esac

msg() { [ "$QUIET" = "0" ] && echo "$1"; }

json_escape() {
    # Экранируем \ и " для JSON
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

severity_of() {
    case "$1" in
        */bin/*|*/xbin/*|*sepolicy*|*/etc/init/*)        echo "CRITICAL" ;;
        *build.prop|*/framework/*|*/lib/*|*/lib64/*)      echo "HIGH" ;;
        */fonts/*|*/media/*|*/etc/*)                      echo "MEDIUM" ;;
        *)                                                echo "LOW" ;;
    esac
}

do_scan() {
    [ ! -d "$MODULES_DIR" ] && { msg "! Папка модулей не найдена"; exit 1; }

    : > "$MAP_FILE"
    scanned=0
    mod_count=0

    for module_dir in "$MODULES_DIR"/*/; do
        [ -d "$module_dir" ] || continue
        mod_name=$(basename "$module_dir")

        [ "$mod_name" = "$SELF_ID" ] && continue
        [ -f "$module_dir/disable" ]  && continue
        [ -f "$module_dir/remove" ]   && continue
        [ -d "$module_dir/system" ]   || continue

        mod_count=$((mod_count + 1))

        find "$module_dir/system" -type f 2>/dev/null | while IFS= read -r fpath; do
            rel="${fpath#${module_dir}system}"
            # .replace-маркеры каталогов пропускаем как обычные файлы не считаем
            case "$rel" in */.replace) continue ;; esac
            printf '%s|%s\n' "$rel" "$mod_name" >> "$MAP_FILE"
        done
    done

    scanned=$(wc -l < "$MAP_FILE" 2>/dev/null || echo 0)
    scan_time=$(date '+%Y-%m-%dT%H:%M:%S')

    # Группировка: пути, встречающиеся более одного раза
    : > "$LOG_FILE"
    conflicts=0
    json_items=""

    sort "$MAP_FILE" | awk -F'|' '
        {
            if ($1 == prev) { owners = owners " " $2 }
            else {
                if (cnt > 1) print prev "|" owners
                prev = $1; owners = $2; cnt = 1; next
            }
            cnt++
        }
        END { if (cnt > 1) print prev "|" owners }
    ' | while IFS='|' read -r path owners; do
        winner=$(echo "$owners" | tr ' ' '\n' | sort | tail -1)
        sev=$(severity_of "$path")

        echo "[$sev] $path" >> "$LOG_FILE"
        echo "    modules: $owners" >> "$LOG_FILE"
        echo "    winner:  $winner" >> "$LOG_FILE"
        echo "" >> "$LOG_FILE"

        # JSON-элементы копим во временный файл (subshell не даёт переменные наружу)
        ep=$(json_escape "$path")
        eo=$(echo "$owners" | tr ' ' '\n' | sed 's/.*/"&"/' | tr '\n' ',' | sed 's/,$//')
        printf '{"path":"%s","modules":[%s],"winner":"%s","severity":"%s"}\n' \
            "$ep" "$eo" "$winner" "$sev" >> "$MCD_DIR/.json_items.tmp"
    done

    # Собираем итоговый JSON
    conflicts=0
    items=""
    if [ -f "$MCD_DIR/.json_items.tmp" ]; then
        conflicts=$(wc -l < "$MCD_DIR/.json_items.tmp")
        items=$(sed 's/$/,/' "$MCD_DIR/.json_items.tmp" | tr -d '\n' | sed 's/,$//')
        rm -f "$MCD_DIR/.json_items.tmp"
    fi

    cat > "$JSON_FILE" <<EOF
{
  "scan_time": "$scan_time",
  "modules_scanned": $mod_count,
  "files_scanned": $scanned,
  "conflicts_count": $conflicts,
  "conflicts": [$items]
}
EOF

    rm -f "$MAP_FILE"

    if [ "$conflicts" -gt 0 ]; then
        msg "! Найдено конфликтов: $conflicts (модулей: $mod_count, файлов: $scanned)"
        msg "  Отчёт: mcd-ctrl report"
    else
        msg "- Конфликтов нет (модулей: $mod_count, файлов: $scanned)"
    fi
}

do_report() {
    if [ "$2" = "--json" ]; then
        [ -f "$JSON_FILE" ] && cat "$JSON_FILE" || echo '{"error":"no scan data"}'
    else
        if [ -s "$LOG_FILE" ]; then
            cat "$LOG_FILE"
        else
            echo "- Конфликтов не обнаружено. Запустите: mcd-ctrl scan"
        fi
    fi
}

case "$1" in
    scan)   do_scan ;;
    report) do_report "$@" ;;
    clear)  rm -f "$LOG_FILE" "$JSON_FILE"; msg "- Логи очищены" ;;
    *)
        echo "Module Conflict Detector v1.0"
        echo "Использование: mcd-ctrl scan|report [--json]|clear"
        ;;
esac